<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)xunit.core\2.4.0\build\xunit.core.targets" Condition="Exists('$(NuGetPackageRoot)xunit.core\2.4.0\build\xunit.core.targets')" />
    <Import Project="$(NuGetPackageRoot)specflow\2.4.0\build\SpecFlow.targets" Condition="Exists('$(NuGetPackageRoot)specflow\2.4.0\build\SpecFlow.targets')" />
    <Import Project="$(NuGetPackageRoot)selenium.firefox.webdriver\0.21.0\build\Selenium.Firefox.WebDriver.targets" Condition="Exists('$(NuGetPackageRoot)selenium.firefox.webdriver\0.21.0\build\Selenium.Firefox.WebDriver.targets')" />
    <Import Project="$(NuGetPackageRoot)entityframework\6.4.4\buildTransitive\EntityFramework.targets" Condition="Exists('$(NuGetPackageRoot)entityframework\6.4.4\buildTransitive\EntityFramework.targets')" />
  </ImportGroup>
</Project>